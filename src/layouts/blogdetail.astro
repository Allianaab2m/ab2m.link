---
import Base from './base.astro'
---

<Base>
  <slot />
</Base>
<style>
  :global(h2) {
    font-size: 24px;
    border-left-width: 2px;
    padding-left: 8px;
    margin-top: 6px;
  }
  :global(blockquote) {
    border-left-width: 4px;
    border-left-color: gray;
    padding-left: 8px;
    font-style: italic;
    margin: 4px 0px;
  }
  :global(ul) {
    list-style: inside;
    margin-left: 8px;
  }
  :global(code) {
    background-color: #292524;
    border-radius: 2px;
    padding: 0px 4px;
  }
  :global(.rlc-container) {
    display: grid;
    overflow: hidden;
    grid-template-columns: 3fr 1fr;
    grid-template-rows: 1fr;
    grid-column-gap: 0px;
    grid-row-gap: 0px;
    align-items: stretch;
    width: 100%;
    max-width: 800px;
    margin: 1rem auto 1.5rem;
    padding: 0.25rem;
    text-decoration: none;
    border: 1px solid;
    border-radius: 0.25rem;
  }
  :global(.rlc-info) {
    grid-area: 1/ 1 / 2 / 2;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    justify-content: space-between;
    padding: 0.5rem;
    text-align: left;
  }
  :global(.rlc-title) {
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 1.25rem;
    white-space: nowrap;
  }
  :global(.rlc-description) {
    overflow: hidden;
    font-size: 0.875rem;
    line-height: 1rem;
    height: 2rem;
  }
  :global(.rlc-url-container) {
    display: flex;
    align-items: bottom;
  }
  :global(.rlc-favicon) {
    display: flex;
    flex-direction: column;
    align-items: bottom;
    margin-right: 4px;
    width: 16px;
    height: 16px;
  }
  :global(.rlc-url) {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 1rem;
  }
  :global(.rlc-image-container) {
    display: grid;
    grid-area: 1 / 2 / 2/ 3;
    align-items: center;
    height: 8rem;
  }
  :global(.rlc-image) {
    object-fit: contain;
    margin: auto;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    min-height: 8rem;
    max-height: 8rem;
    border-bottom-right-radius: 0.25rem;
    border-top-right-radius: 0.25rem;
  }
</style>
